      if(!id){ state.studentUnitId=null; state.studentUnit=null; render(); return; }
      state.studentUnitId = id;
      state.loading = "Loading...";
      render();
      state.studentUnit = await loadUnit(id);
      state.studentResults = {};
      if(state.studentUnit && state.studentUnit.los){
        for(const lo of state.studentUnit.los){
          state.studentResults[lo.id] = await loadResults(id, lo.id);
        }
      }
      state.loading = null;

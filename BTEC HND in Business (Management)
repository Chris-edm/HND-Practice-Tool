      submitBtn.innerHTML = '<span class="spinner"></span>Grading...';
      try{
        const sys = "You are grading a BTEC HND Level 5 student's practice answers, strictly against the provided lecture/tutorial source content and the Pass/Merit/Distinction criteria for this learning outcome. Do not reward or expect content beyond what is in the provided source material. For each answer, decide a band: one of \"notyet\" (not yet meeting Pass), \"pass\", \"merit\", or \"distinction\", reflecting the depth of analysis/evaluation shown against the criteria. Give concise, constructive feedback (2-4 sentences) naming a strength and one concrete improvement tied to the criteria. Then give one overall band for the set and a short overall note. Respond ONLY with valid JSON, no preamble, no fences. Shape: {\"items\": [{\"qid\": \"...\", \"band\": \"pass\", \"feedback\": \"...\"}], \"overallBand\": \"merit\", \"overallNote\": \"...\"}.";
        const userMsg = "Learning outcome: " + lo.code + " — " + lo.title +
          "\nPass criteria: " + lo.criteria.pass + "\nMerit criteria: " + lo.criteria.merit + "\nDistinction criteria: " + lo.criteria.distinction +
          "\n\nSource content (slides):\n" + (unit.slidesText||"") +
          "\n\nSource content (tutorial):\n" + (unit.tutorialText||"") +
          "\n\nQuestions and the student's answers:\n" +
          qs.map((q,i)=>"Q"+(i+1)+" [qid:"+q.id+"] "+q.question+"\nModel answer points: "+(q.modelAnswerPoints||[]).join("; ")+"\nStudent answer: "+state.answers[q.id]).join("\n\n");
        const result = await callAI(sys, userMsg, true);
        state.gradedFeedback = {
          loId: lo.id,
          items: result.items || [],
          overallBand: result.overallBand || "notyet",
          overallNote: result.overallNote || ""
        };
        const results = state.studentResults[lo.id] || [];
        results.push({date: new Date().toISOString(), overallBand: state.gradedFeedback.overallBand, overallNote: state.gradedFeedback.overallNote});
        state.studentResults[lo.id] = results;
        await saveResults(unit.id, lo.id, results);
        render();
      }catch(err){
        showToast("Grading failed: " + err.message);
        submitBtn.disabled = false;
        submitBtn.textContent = "Submit for grading";
      }
    };
  }

  // ---------- Init ----------
  async function init(){
    app.innerHTML = `<div class="empty"><div class="big">Loading ledger...</div></div>`;
    try{
      const snap = await getDoc(doc(db, "settings", "main"));
      if(snap.exists()) state.settings = snap.data();
    }catch(e){ /* no settings saved yet */ }
    await loadUnitsIndex();
    render();
  }
  init();
</script>
</body>
</html>

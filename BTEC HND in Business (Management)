  function renderQuestionEditList(qs){
    if(!qs || !qs.length) return `<p class="small-note">No questions generated yet.</p>`;
    return qs.map((q,i)=>`<div class="qedit">
      <div class="q-number">Question ${i+1} — targets ${(q.targetCriteria||[]).join(", ")}</div>
      <div class="q-text">${escapeHtml(q.question)}</div>
      <details><summary class="small-note" style="cursor:pointer;">Model answer points (for grading reference)</summary>
        <ul style="font-size:12.5px;color:var(--ink-soft);">${(q.modelAnswerPoints||[]).map(p=>`<li>${escapeHtml(p)}</li>`).join("")}</ul>

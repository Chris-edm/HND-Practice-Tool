  function studentLoOverviewHtml(){
    const unit = state.studentUnit;
    if(!unit.los || !unit.los.length){
      return `<div class="empty"><div class="big">No learning outcomes set up yet</div>Check back once your tutor has added them.</div>`;
    }
    let html = `<div class="card"><h2>${escapeHtml(unit.name)}</h2><p class="hint">Your current standing against each learning outcome, based on your most recent attempt.</p>`;
    unit.los.forEach(lo=>{
      const results = state.studentResults[lo.id] || [];
      const latest = results[results.length-1];
      const band = latest ? latest.overallBand : "unattempted";
      html += `<div class="lo-item">
        <div class="lo-head">
          <div>
            <span class="lo-code">${escapeHtml(lo.code||'')}</span>
            <div class="lo-title">${escapeHtml(lo.title||'')}</div>
            <div class="lo-desc">${escapeHtml(lo.description||'')}</div>
          </div>
          <div style="text-align:right;">
            ${bandStamp(band)}
            <div style="margin-top:8px;">
              <button class="btn secondary open-lo-btn" data-lo-id="${lo.id}">Practice this LO</button>
            </div>
          </div>
        </div>
      </div>`;
    });
    html += `</div>`;
    return html;
  }

  function studentQuestionsHtml(){
    const unit = state.studentUnit;
    const lo = unit.los.find(l=>l.id===state.studentLoId);
    const qs = state.studentQuestions || [];
    let html = `<div class="card">
      <button class="link-btn" id="back-to-los-btn">&larr; Back to learning outcomes</button>
      <h2 style="margin-top:12px;">${escapeHtml(lo.code||'')} — ${escapeHtml(lo.title||'')}</h2>
      <p class="hint">${escapeHtml(lo.description||'')}</p>`;

    if(!qs.length){
      html += `<p class="small-note">No practice questions available for this learning outcome yet.</p></div>`;
      return html;
    }

    qs.forEach((q,i)=>{
      const fb = state.gradedFeedback && state.gradedFeedback.loId===lo.id
        ? state.gradedFeedback.items.find(it=>it.qid===q.id) : null;
      html += `<div class="q-block">
        <div class="q-number">Question ${i+1}</div>
        <div class="q-text">${escapeHtml(q.question)}</div>
        <div class="q-targets">${(q.targetCriteria||[]).map(c=>`<span class="stamp neutral">${escapeHtml(c)}</span>`).join("")}</div>
        <textarea class="answer-box" data-qid="${q.id}" placeholder="Write your response here...">${escapeHtml(state.answers[q.id]||"")}</textarea>
        ${fb ? `<div class="feedback-box">
          <div class="band-line">${bandStamp(fb.band, true)}</div>
          <div>${escapeHtml(fb.feedback)}</div>
        </div>` : ""}
      </div>`;
    });

    html += `<button class="btn" id="submit-answers-btn">Submit for grading</button>`;
    if(state.gradedFeedback && state.gradedFeedback.loId===lo.id){
      html += `<div class="feedback-box" style="margin-top:16px;border:1px solid var(--line);">
        <div class="band-line"><b style="font-family:var(--mono);font-size:11px;text-transform:uppercase;">Overall for this attempt:</b> ${bandStamp(state.gradedFeedback.overallBand, true)}</div>
        <div>${escapeHtml(state.gradedFeedback.overallNote||"")}</div>
      </div>`;
    }
    html += `</div>`;
    return html;
  }

  function escapeHtml(s){
    if(s===undefined || s===null) return "";
    return String(s).replace(/[&<>"']/g, c=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]));
  }

  // ---------- Event handling ----------
  function attachHandlers(){
    app.querySelectorAll("[data-mode]").forEach(btn=>{
      btn.onclick = () => {
        const target = btn.dataset.mode;
        if(target === "instructor" && !state.instructorUnlocked){
          return; // shouldn't happen, button only renders when unlocked
        }
        state.mode = target;
        render();
      };
    });

    const staffBtn = document.getElementById("staff-access-btn");
    if(staffBtn) staffBtn.onclick = async () => {
      const s = state.settings;
      if(!s.passcode){
        const newPass = prompt("No staff passcode is set yet. Create one now to protect the instructor area:");
        if(!newPass) return;
        state.settings.passcode = newPass;
        await setDoc(doc(db, "settings", "main"), state.settings);
        state.instructorUnlocked = true;
        state.mode = "instructor";
        showToast("Staff passcode created. Keep it to yourself and any colleagues you assign.");
        render();
        return;
      }
      const entered = prompt("Enter the staff passcode:");
      if(entered === null) return;
      if(entered === s.passcode){
        state.instructorUnlocked = true;
        state.mode = "instructor";
        render();
      } else {
        showToast("Incorrect passcode.");
      }
    };

    if(state.mode === "instructor"){
      attachInstructorHandlers();

    if(logoInput) logoInput.onchange = () => {
      const f = logoInput.files[0]; if(!f) return;
      if(f.size > 700 * 1024){
        showToast("Please use a smaller logo image (under ~700KB) so it fits Firestore's document size limit.");
        return;
      }

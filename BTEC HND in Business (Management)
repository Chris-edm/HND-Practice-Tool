      reader.onload = () => { pendingLogoDataUrl = reader.result; };
      reader.readAsDataURL(f);
    };

    const saveCentreBtn = document.getElementById("save-centre-settings-btn");
    if(saveCentreBtn) saveCentreBtn.onclick = async () => {
      state.settings.centreName = document.getElementById("centre-name-input").value.trim();
      if(pendingLogoDataUrl) state.settings.logoDataUrl = pendingLogoDataUrl;
      const newPass = document.getElementById("new-passcode-input").value.trim();
      if(newPass) state.settings.passcode = newPass;
      try{
        await setDoc(doc(db, "settings", "main"), state.settings);
        showToast("Centre settings saved.");
        render();
      }catch(e){
        showToast("Could not save settings: " + e.message);
      }
    };

    const unitSelect = document.getElementById("unit-select");
    if(unitSelect) unitSelect.onchange = async (e) => {
      const id = e.target.value;
      if(!id){ state.currentUnitId=null; state.currentUnit=null; render(); return; }
      state.currentUnitId = id;
      state.loading = "Loading unit...";
      render();
      state.currentUnit = await loadUnit(id);
      state._questionsCache = {};
      if(state.currentUnit && state.currentUnit.los){
        for(const lo of state.currentUnit.los){
          state._questionsCache[lo.id] = await loadQuestions(id, lo.id);
        }
      }
      state.loading = null;
      render();
    };

    const newUnitBtn = document.getElementById("new-unit-btn");
    if(newUnitBtn) newUnitBtn.onclick = async () => {
      const id = uid("unit");
      const unit = { id, name: "Untitled unit", assignmentBrief:"", slidesText:"", tutorialText:"", los:[] };
      await saveUnit(unit);
      state.unitsIndex.push({id, name: unit.name});
      state.currentUnitId = id;
      state.currentUnit = unit;
      state._questionsCache = {};
      render();
    };

    const unitNameInput = document.getElementById("unit-name");
    const saveNameBtn = document.getElementById("save-unit-name-btn");
    if(saveNameBtn) saveNameBtn.onclick = async () => {
      state.currentUnit.name = unitNameInput.value.trim() || "Untitled unit";
      await saveUnit(state.currentUnit);
      const idx = state.unitsIndex.find(u=>u.id===state.currentUnit.id);
      if(idx) idx.name = state.currentUnit.name;
      showToast("Unit name saved.");
      render();
    };

    const deleteUnitBtn = document.getElementById("delete-unit-btn");
    if(deleteUnitBtn) deleteUnitBtn.onclick = async () => {
      if(!confirm("Delete this unit? This cannot be undone.")) return;
      state.unitsIndex = state.unitsIndex.filter(u=>u.id!==state.currentUnit.id);
      try{ await deleteUnitDoc(state.currentUnit.id); }catch(e){}
      state.currentUnitId = null; state.currentUnit = null;
      showToast("Unit deleted.");
      render();
    };

    const briefFile = document.getElementById("brief-file");
    if(briefFile) briefFile.onchange = async () => {
      const f = briefFile.files[0]; if(!f) return;
      document.getElementById("brief-file-meta").textContent = "Extracting text from " + f.name + "...";
      try{
        const text = await extractFile(f);
        document.getElementById("brief-text").value = text;
        document.getElementById("brief-file-meta").textContent = "Extracted " + text.split(/\s+/).length + " words from " + f.name + ".";
      }catch(err){
        document.getElementById("brief-file-meta").textContent = "Could not read file: " + err.message;
      }
    };

    const extractBtn = document.getElementById("extract-los-btn");
    if(extractBtn) extractBtn.onclick = async () => {
      const briefText = document.getElementById("brief-text").value.trim();
      if(!briefText){ showToast("Paste or upload the assignment brief first."); return; }
      extractBtn.disabled = true;
      extractBtn.innerHTML = '<span class="spinner"></span>Extracting...';
      try{
        const sys = "You are assisting a BTEC HND Level 5 tutor. You extract structured Learning Outcomes and Pass/Merit/Distinction assessment criteria from an assignment brief. Respond ONLY with valid JSON, no preamble, no markdown fences. JSON shape: {\"los\": [{\"code\": \"LO1\", \"title\": \"short title\", \"description\": \"1-2 sentence description\", \"criteria\": {\"pass\": \"P1: ...; P2: ...\", \"merit\": \"M1: ...\", \"distinction\": \"D1: ...\"}}]}. Use the exact criterion codes and wording found in the brief where possible; if criteria are not explicit for an LO, write a brief best-effort criterion in the same style.";
        const userMsg = "Assignment brief:\n\n" + briefText;
        const result = await callAI(sys, userMsg, true);
        const los = (result.los || []).map(lo => ({
          id: uid("lo"),
          code: lo.code || "",
          title: lo.title || "",
          description: lo.description || "",
          criteria: {
            pass: (lo.criteria && lo.criteria.pass) || "",
            merit: (lo.criteria && lo.criteria.merit) || "",
            distinction: (lo.criteria && lo.criteria.distinction) || ""
          }
        }));
        state.currentUnit.assignmentBrief = briefText;
        state.currentUnit.los = los;
        await saveUnit(state.currentUnit);
        state._questionsCache = {};
        for(const lo of los){ state._questionsCache[lo.id] = []; }
        showToast("Learning outcomes extracted — review and edit below.");
        render();
      }catch(err){
        showToast("Extraction failed: " + err.message);
        extractBtn.disabled = false;
        extractBtn.textContent = "Extract learning outcomes";
      }
    };

    const addLoBtn = document.getElementById("add-lo-btn");
    if(addLoBtn) addLoBtn.onclick = async () => {
      const lo = {id: uid("lo"), code:"LO"+((state.currentUnit.los.length)+1), title:"", description:"", criteria:{pass:"",merit:"",distinction:""}};
      state.currentUnit.los.push(lo);
      state._questionsCache[lo.id] = [];
      await saveUnit(state.currentUnit);
      render();
    };

    app.querySelectorAll(".lo-save-btn").forEach(btn=>{
      btn.onclick = async () => {
        const loId = btn.dataset.loId;
        const item = app.querySelector(`.lo-item[data-lo-id="${loId}"]`);
        const lo = state.currentUnit.los.find(l=>l.id===loId);
        item.querySelectorAll(".lo-field").forEach(f=>{
          const field = f.dataset.field;
          if(field==="pass"||field==="merit"||field==="distinction"){
            lo.criteria[field] = f.value;
          } else {
            lo[field] = f.value;
          }
        });
        await saveUnit(state.currentUnit);
        showToast("Learning outcome saved.");
        render();
      };
    });

    app.querySelectorAll(".lo-delete-btn").forEach(btn=>{
      btn.onclick = async () => {
        if(!confirm("Delete this learning outcome and its questions?")) return;
        const loId = btn.dataset.loId;
        state.currentUnit.los = state.currentUnit.los.filter(l=>l.id!==loId);
        await saveUnit(state.currentUnit);
        try{ await deleteQuestionsDoc(state.currentUnit.id, loId); }catch(e){}
        delete state._questionsCache[loId];
        render();
      };
    });

    const slidesFile = document.getElementById("slides-file");
    if(slidesFile) slidesFile.onchange = async () => {
      const f = slidesFile.files[0]; if(!f) return;
      document.getElementById("slides-file-meta").textContent = "Extracting text from " + f.name + "...";
      try{
        const text = await extractFile(f);
        document.getElementById("slides-text").value = text;
        document.getElementById("slides-file-meta").textContent = "Extracted " + text.split(/\s+/).length + " words from " + f.name + ".";
      }catch(err){
        document.getElementById("slides-file-meta").textContent = "Could not read file: " + err.message;
      }
    };
    const tutorialFile = document.getElementById("tutorial-file");
    if(tutorialFile) tutorialFile.onchange = async () => {
      const f = tutorialFile.files[0]; if(!f) return;
      document.getElementById("tutorial-file-meta").textContent = "Extracting text from " + f.name + "...";
      try{
        const text = await extractFile(f);
        document.getElementById("tutorial-text").value = text;
        document.getElementById("tutorial-file-meta").textContent = "Extracted " + text.split(/\s+/).length + " words from " + f.name + ".";
      }catch(err){
        document.getElementById("tutorial-file-meta").textContent = "Could not read file: " + err.message;
      }
    };

    const saveContentBtn = document.getElementById("save-content-btn");
    if(saveContentBtn) saveContentBtn.onclick = async () => {
      state.currentUnit.slidesText = document.getElementById("slides-text").value;
      state.currentUnit.tutorialText = document.getElementById("tutorial-text").value;
      await saveUnit(state.currentUnit);
      showToast("Source content saved.");
    };

    app.querySelectorAll(".gen-questions-btn").forEach(btn=>{
      btn.onclick = async () => {
        const loId = btn.dataset.loId;
        const lo = state.currentUnit.los.find(l=>l.id===loId);
        const unit = state.currentUnit;
        if(!unit.slidesText && !unit.tutorialText){
          showToast("Add lecture slide or tutorial content first.");
          return;
        }
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner"></span>Generating...';
        try{
          const sys = "You write practice questions for BTEC HND Level 5 students, strictly scaffolded to help them tackle a specific assignment task and meet specific assessment criteria. Rules: (1) Base every question ONLY on the provided lecture/tutorial content — never introduce theorists, models or frameworks not present in that content. (2) Questions must be scenario/case-based, written at analysis and evaluation level (not simple recall or definitions). (3) Each question should target one or more named criteria for this learning outcome, and should visibly help the student practise the kind of thinking the assignment brief will demand. (4) For each question provide brief model-answer bullet points (grading reference only, not shown to students up front) that a marker would expect to see, referencing only the given source content. Respond ONLY with valid JSON, no preamble, no fences. Shape: {\"questions\": [{\"question\": \"...\", \"targetCriteria\": [\"P1\",\"M1\"], \"modelAnswerPoints\": [\"...\", \"...\"]}]}. Generate 4 questions.";
          const userMsg = "Learning outcome: " + lo.code + " — " + lo.title + "\nDescription: " + lo.description +
            "\nPass criteria: " + lo.criteria.pass + "\nMerit criteria: " + lo.criteria.merit + "\nDistinction criteria: " + lo.criteria.distinction +
            "\n\nAssignment brief (for scenario context):\n" + (unit.assignmentBrief||"(none provided)") +
            "\n\nLecture slide content:\n" + (unit.slidesText||"(none provided)") +
            "\n\nTutorial material:\n" + (unit.tutorialText||"(none provided)");
          const result = await callAI(sys, userMsg, true);
          const questions = (result.questions||[]).map(q=>({
            id: uid("q"),
            question: q.question,
            targetCriteria: q.targetCriteria||[],
            modelAnswerPoints: q.modelAnswerPoints||[]
          }));
          await saveQuestions(unit.id, loId, questions);
          state._questionsCache[loId] = questions;
          showToast("Questions generated for " + lo.code + ".");
          render();
        }catch(err){
          showToast("Generation failed: " + err.message);
          btn.disabled = false;
          btn.textContent = "Generate questions";
        }
      };
    });
  }


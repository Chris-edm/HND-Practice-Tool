      </div>
      <div class="unit-select-row" style="margin-top:12px;">
        <select id="student-unit-select">
          <option value="">— Select a unit —</option>
          ${state.unitsIndex.map(u=>`<option value="${u.id}" ${state.studentUnitId===u.id?'selected':''}>${escapeHtml(u.name)}</option>`).join("")}
        </select>
      </div>
    </div>`;

    if(!state.unitsIndex.length){
      html += `<div class="empty"><div class="big">No units published yet</div>Ask your tutor to add practice material for this unit.</div>`;
      return html;

      box.oninput = () => { state.answers[box.dataset.qid] = box.value; };
    });

    const submitBtn = document.getElementById("submit-answers-btn");
    if(submitBtn) submitBtn.onclick = async () => {
      const lo = state.studentUnit.los.find(l=>l.id===state.studentLoId);
      const unit = state.studentUnit;
      const qs = state.studentQuestions;
      const unanswered = qs.filter(q => !(state.answers[q.id]||"").trim());
      if(unanswered.length){
        showToast("Please answer all questions before submitting.");
        return;

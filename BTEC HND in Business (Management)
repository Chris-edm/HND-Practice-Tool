  // ===================== STUDENT VIEW =====================
  function studentHtml(){
    let html = `<div class="card">
      <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;">
        <h2 style="margin:0;">Choose your unit</h2>
        <div class="small-note">

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Unit Ledger — HND Practice &amp; Standing</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Spectral:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/mammoth/1.6.0/mammoth.browser.min.js"></script>
<style>
  :root{
    --ink:#16233F;
    --ink-soft:#3B4A6B;
    --paper:#EEF0F1;
    --paper-raised:#FFFFFF;
    --line:#C9CDD4;
    --folder:#D9C9A3;
    --folder-dark:#B49F6E;
    --pass:#3B6E8F;
    --pass-bg:#E4EDF2;
    --merit:#B5852C;
    --merit-bg:#F5EBD8;
    --dist:#2F5233;
    --dist-bg:#E3EAE1;
    --notyet:#9A4632;
    --notyet-bg:#F3E4DE;
    --radius:3px;
    --serif:'Spectral', Georgia, serif;
    --sans:'Inter', -apple-system, sans-serif;
    --mono:'IBM Plex Mono', monospace;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    font-family:var(--sans);
    background:var(--paper);
    color:var(--ink);
    -webkit-font-smoothing:antialiased;
  }
  .app{max-width:960px;margin:0 auto;padding:0 20px 80px;}

  /* Top bar */
  .topbar{
    display:flex;align-items:center;justify-content:space-between;
    padding:22px 0 16px;border-bottom:2px solid var(--ink);
    margin-bottom:24px;
  }
  .brand{display:flex;align-items:baseline;gap:10px;}
  .brand h1{font-family:var(--serif);font-size:22px;font-weight:700;margin:0;letter-spacing:0.2px;}
  .brand .sub{font-family:var(--mono);font-size:11px;color:var(--ink-soft);text-transform:uppercase;letter-spacing:1px;}
  .mode-toggle{display:flex;border:1.5px solid var(--ink);border-radius:var(--radius);overflow:hidden;}
  .mode-toggle button{
    border:none;background:var(--paper-raised);color:var(--ink);
    font-family:var(--mono);font-size:11px;text-transform:uppercase;letter-spacing:0.8px;
    padding:9px 16px;cursor:pointer;font-weight:600;
  }
  .mode-toggle button.active{background:var(--ink);color:#fff;}

  /* Cards */
  .card{
    background:var(--paper-raised);border:1px solid var(--line);border-radius:var(--radius);
    padding:22px 24px;margin-bottom:18px;
  }
  .card h2{font-family:var(--serif);font-size:19px;margin:0 0 4px;font-weight:600;}
  .card .hint{font-size:13px;color:var(--ink-soft);margin:0 0 16px;}
  label{display:block;font-family:var(--mono);font-size:11px;text-transform:uppercase;letter-spacing:0.6px;color:var(--ink-soft);margin-bottom:6px;margin-top:14px;}
  label:first-of-type{margin-top:0;}
  input[type=text], textarea, select{
    width:100%;font-family:var(--sans);font-size:14px;padding:10px 12px;
    border:1px solid var(--line);border-radius:var(--radius);background:#fff;color:var(--ink);
    resize:vertical;
  }
  textarea{min-height:90px;line-height:1.5;}
  input[type=text]:focus, textarea:focus, select:focus{outline:2px solid var(--ink-soft);outline-offset:1px;}
  .row{display:flex;gap:14px;flex-wrap:wrap;}
  .row > *{flex:1;min-width:220px;}

  button.btn{
    font-family:var(--mono);font-size:11.5px;text-transform:uppercase;letter-spacing:0.6px;font-weight:600;
    background:var(--ink);color:#fff;border:none;border-radius:var(--radius);
    padding:11px 18px;cursor:pointer;margin-top:14px;margin-right:8px;
  }
  button.btn:hover{background:var(--ink-soft);}
  button.btn.secondary{background:#fff;color:var(--ink);border:1.5px solid var(--ink);}
  button.btn.secondary:hover{background:var(--paper);}
  button.btn.danger{background:#fff;color:var(--notyet);border:1.5px solid var(--notyet);}
  button.btn:disabled{opacity:0.5;cursor:not-allowed;}
  .file-btn{display:inline-block;font-family:var(--mono);font-size:11px;text-transform:uppercase;
    border:1px dashed var(--ink-soft);border-radius:var(--radius);padding:8px 12px;cursor:pointer;
    color:var(--ink-soft);margin-top:8px;background:#fbfbfa;}
  .file-btn input{display:none;}
  .file-meta{font-size:12px;color:var(--ink-soft);margin-top:6px;font-style:italic;}

  /* Unit selector row */
  .unit-select-row{display:flex;gap:10px;align-items:center;margin-bottom:18px;}
  .unit-select-row select{flex:1;}

  /* Stamp badges */
  .stamp{
    display:inline-flex;align-items:center;gap:6px;font-family:var(--mono);font-weight:700;
    font-size:11px;letter-spacing:0.8px;text-transform:uppercase;
    padding:5px 10px;border-radius:2px;transform:rotate(-1.5deg);
    border:2px solid currentColor;
  }
  .stamp.pass{color:var(--pass);background:var(--pass-bg);}
  .stamp.merit{color:var(--merit);background:var(--merit-bg);}
  .stamp.dist{color:var(--dist);background:var(--dist-bg);}
  .stamp.notyet{color:var(--notyet);background:var(--notyet-bg);}
  .stamp.neutral{color:var(--ink-soft);background:var(--paper);border-color:var(--line);transform:none;}
  @keyframes stampdown{
    0%{transform:rotate(-1.5deg) scale(2.2);opacity:0;}
    60%{transform:rotate(-1.5deg) scale(0.95);opacity:1;}
    100%{transform:rotate(-1.5deg) scale(1);opacity:1;}
  }
  .stamp.fresh{animation:stampdown 0.35s ease-out;}

  /* LO list */
  .lo-item{
    border:1px solid var(--line);border-left:4px solid var(--folder-dark);border-radius:var(--radius);
    padding:14px 16px;margin-bottom:10px;background:#fff;
  }
  .lo-head{display:flex;justify-content:space-between;align-items:flex-start;gap:12px;flex-wrap:wrap;}
  .lo-code{font-family:var(--mono);font-weight:700;color:var(--folder-dark);font-size:13px;}
  .lo-title{font-family:var(--serif);font-size:16px;font-weight:600;margin:2px 0 4px;}
  .lo-desc{font-size:13px;color:var(--ink-soft);line-height:1.5;}
  .criteria-row{display:flex;gap:14px;margin-top:10px;font-size:12px;flex-wrap:wrap;}
  .criteria-col{flex:1;min-width:160px;}
  .criteria-col b{font-family:var(--mono);font-size:10.5px;letter-spacing:0.5px;text-transform:uppercase;}
  .criteria-col ul{margin:4px 0 0;padding-left:16px;}
  .criteria-col li{margin-bottom:3px;color:var(--ink-soft);}

  /* Questions */
  .q-block{border-top:1px solid var(--line);padding-top:16px;margin-top:16px;}
  .q-number{font-family:var(--mono);font-size:11px;color:var(--folder-dark);font-weight:700;}
  .q-text{font-family:var(--serif);font-size:16px;margin:6px 0 10px;line-height:1.5;}
  .q-targets{margin-bottom:10px;}
  .q-targets .stamp.neutral{margin-right:6px;font-size:10px;padding:3px 7px;}
  .feedback-box{background:var(--paper);border-radius:var(--radius);padding:12px 14px;margin-top:10px;font-size:13.5px;line-height:1.55;}
  .feedback-box .band-line{margin-bottom:8px;display:flex;gap:8px;align-items:center;}

  /* Q edit list (instructor) */
  .qedit{border:1px solid var(--line);border-radius:var(--radius);padding:12px 14px;margin-bottom:10px;background:#fbfbfa;}
  .qedit .q-text{font-size:14px;}
  .qedit textarea{min-height:50px;font-size:13px;}

  .empty{text-align:center;padding:40px 20px;color:var(--ink-soft);font-size:14px;}
  .empty .big{font-family:var(--serif);font-size:20px;color:var(--ink);margin-bottom:6px;}

  .toast{
    position:fixed;bottom:20px;right:20px;background:var(--ink);color:#fff;
    padding:12px 18px;border-radius:var(--radius);font-size:13px;font-family:var(--sans);
    box-shadow:0 6px 20px rgba(0,0,0,0.2);z-index:1000;max-width:320px;
  }
  .spinner{display:inline-block;width:13px;height:13px;border:2px solid rgba(255,255,255,0.4);
    border-top-color:#fff;border-radius:50%;animation:spin 0.7s linear infinite;margin-right:8px;vertical-align:-2px;}
  @keyframes spin{to{transform:rotate(360deg);}}

  .dashboard-summary{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:6px;}
  .summary-tile{flex:1;min-width:130px;border:1px solid var(--line);border-radius:var(--radius);
    padding:12px 14px;background:#fff;text-align:center;}
  .summary-tile .num{font-family:var(--serif);font-size:26px;font-weight:700;}
  .summary-tile .lbl{font-family:var(--mono);font-size:10px;text-transform:uppercase;color:var(--ink-soft);letter-spacing:0.5px;}

  .link-btn{background:none;border:none;color:var(--ink-soft);text-decoration:underline;cursor:pointer;font-size:12px;padding:0;font-family:var(--sans);}
  .divider{border:none;border-top:1px solid var(--line);margin:20px 0;}
  .small-note{font-size:12px;color:var(--ink-soft);margin-top:4px;}

  .brand{display:flex;align-items:center;gap:12px;}
  .brand-logo{height:36px;max-width:110px;object-fit:contain;}
  .brand-names{display:flex;flex-direction:column;}
  .brand-names .centre{font-family:var(--mono);font-size:10.5px;text-transform:uppercase;letter-spacing:0.8px;color:var(--ink-soft);}
  .staff-link{font-family:var(--mono);font-size:10.5px;text-transform:uppercase;letter-spacing:0.6px;
    color:var(--ink-soft);background:none;border:none;cursor:pointer;text-decoration:underline;margin-right:10px;}
  .logo-preview{height:44px;max-width:140px;object-fit:contain;border:1px dashed var(--line);padding:4px;background:#fff;}
</style>
</head>
<body>
<div class="app" id="app"></div>

<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
import { getFirestore, doc, getDoc, setDoc, deleteDoc, collection, getDocs } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js";

const firebaseConfig = {
  apiKey: "AIzaSyDxMfpFVUSU8lDizutQLiZ7Dov0Ihz9KwE",
  authDomain: "edm-global-campus.firebaseapp.com",
  projectId: "edm-global-campus",
  storageBucket: "edm-global-campus.firebasestorage.app",
  messagingSenderId: "390917281071",
  appId: "1:390917281071:web:7dbbf7da5b0c68a935fdda"
};
const GEMINI_API_KEY = "AQ.Ab8RN6LzWe2fPoVI2LZXFV8WqQY6U2KyPeXSPy4Azc-7Fd0-Qg";

const fbApp = initializeApp(firebaseConfig);
const db = getFirestore(fbApp);

  // ---------- Constants ----------
  const MODEL = "gemini-2.5-flash";
  pdfjsLib.GlobalWorkerOptions.workerSrc = "https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js";

  // ---------- State ----------
  let state = {
    mode: "instructor", // instructor | student
    unitsIndex: [], // [{id,name}]
    currentUnitId: null,
    currentUnit: null, // full unit object when loaded
    studentUnitId: null,
    studentUnit: null,
    studentLoId: null,
    studentQuestions: null,
    studentResults: {}, // loId -> results array
    loading: null,
    answers: {}, // qid -> text
    gradedFeedback: null, // {loId, items:[{qid, band, feedback}], overall}
    settings: { centreName: "", logoDataUrl: "", passcode: "" },
    instructorUnlocked: false,
    studentId: localStorage.getItem("unitLedgerStudentId") || "",
  };

  function uid(prefix){ return prefix + "_" + Math.random().toString(36).slice(2,10); }

  function showToast(msg, ms){
    const el = document.createElement("div");
    el.className = "toast";
    el.textContent = msg;
    document.body.appendChild(el);
    setTimeout(()=>el.remove(), ms || 3200);
  }

  function ensureStudentId(){
    if(state.studentId) return state.studentId;
    let entered = "";
    while(!entered){
      entered = (prompt("Enter your name or student ID. This lets your results follow you if you come back later, even from a different device.") || "").trim();
    }
    state.studentId = entered;
    localStorage.setItem("unitLedgerStudentId", entered);
    return entered;
  }

  // ---------- Gemini API helper ----------
  async function callAI(systemPrompt, userPrompt, expectJson){
    const fullPrompt = (systemPrompt ? systemPrompt + "\n\n" : "") + userPrompt;
    const resp = await fetch(
      "https://generativelanguage.googleapis.com/v1beta/models/" + MODEL + ":generateContent",
      {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "X-goog-api-key": GEMINI_API_KEY
        },
        body: JSON.stringify({
          contents: [{ parts: [{ text: fullPrompt }] }]
        })
      }
    );
    if(!resp.ok){
      throw new Error("API error " + resp.status);
    }
    const data = await resp.json();
    const parts = (data.candidates && data.candidates[0] && data.candidates[0].content && data.candidates[0].content.parts) || [];
    const text = parts.map(p => p.text || "").join("\n").trim();
    if(expectJson){
      let clean = text.replace(/```json/g,"").replace(/```/g,"").trim();
      const firstBrace = clean.search(/[\[{]/);
      if(firstBrace > 0) clean = clean.slice(firstBrace);
      return JSON.parse(clean);
    }
    return text;
  }

  // ---------- File extraction ----------
  async function extractPdfText(file){
    const buf = await file.arrayBuffer();
    const doc = await pdfjsLib.getDocument({data: buf}).promise;
    let out = [];
    for(let i=1;i<=doc.numPages;i++){
      const page = await doc.getPage(i);
      const content = await page.getTextContent();
      const strs = content.items.map(it => it.str);
      out.push(strs.join(" "));
    }
    return out.join("\n\n");
  }

  async function extractPptxText(file){
    const buf = await file.arrayBuffer();
    const zip = await JSZip.loadAsync(buf);
    const slideFiles = Object.keys(zip.files)
      .filter(n => /^ppt\/slides\/slide\d+\.xml$/.test(n))
      .sort((a,b)=>{
        const na = parseInt(a.match(/slide(\d+)\.xml/)[1]);
        const nb = parseInt(b.match(/slide(\d+)\.xml/)[1]);
        return na - nb;
      });
    let out = [];
    for(const name of slideFiles){
      const xml = await zip.files[name].async("string");
      const matches = [...xml.matchAll(/<a:t>([^<]*)<\/a:t>/g)].map(m=>m[1]);
      out.push(matches.join(" "));
    }
    return out.join("\n\n");
  }

  async function extractDocxText(file){
    const buf = await file.arrayBuffer();
    const result = await mammoth.extractRawText({arrayBuffer: buf});
    return result.value;
  }

  async function extractFile(file){
    const lower = file.name.toLowerCase();
    if(lower.endsWith(".pdf")) return await extractPdfText(file);
    if(lower.endsWith(".pptx")) return await extractPptxText(file);
    if(lower.endsWith(".docx")) return await extractDocxText(file);
    throw new Error("Unsupported file type — please upload .pdf, .pptx, or .docx, or paste text instead.");
  }

  // ---------- Storage helpers (Firestore) ----------
  async function loadUnitsIndex(){
    try{
      const snap = await getDocs(collection(db, "units"));
      state.unitsIndex = snap.docs.map(d => ({ id: d.id, name: (d.data().name || "Untitled unit") }));
    }catch(e){ state.unitsIndex = []; showToast("Could not load units: " + e.message); }
  }
  async function loadUnit(unitId){
    try{
      const snap = await getDoc(doc(db, "units", unitId));
      return snap.exists() ? snap.data() : null;
    }catch(e){ showToast("Could not load unit: " + e.message); return null; }
  }
  async function saveUnit(unit){
    await setDoc(doc(db, "units", unit.id), unit);
  }
  async function deleteUnitDoc(unitId){
    await deleteDoc(doc(db, "units", unitId));
  }
  async function loadQuestions(unitId, loId){
    try{
      const snap = await getDoc(doc(db, "questions", unitId + "_" + loId));
      return snap.exists() ? (snap.data().questions || []) : [];
    }catch(e){ return []; }
  }
  async function saveQuestions(unitId, loId, questions){
    await setDoc(doc(db, "questions", unitId + "_" + loId), { questions });
  }
  async function deleteQuestionsDoc(unitId, loId){
    try{ await deleteDoc(doc(db, "questions", unitId + "_" + loId)); }catch(e){}
  }
  async function loadResults(unitId, loId){
    try{
      const sid = ensureStudentId();
      const snap = await getDoc(doc(db, "results", sid + "_" + unitId + "_" + loId));
      return snap.exists() ? (snap.data().attempts || []) : [];
    }catch(e){ return []; }
  }
  async function saveResults(unitId, loId, results){
    const sid = ensureStudentId();
    await setDoc(doc(db, "results", sid + "_" + unitId + "_" + loId), { attempts: results });
  }

  // ---------- Rendering ----------
  const app = document.getElementById("app");

  function render(){
    app.innerHTML = topbarHtml() + (state.mode === "instructor" ? instructorHtml() : studentHtml());
    attachHandlers();
  }

  function topbarHtml(){
    const s = state.settings;
    const logoHtml = s.logoDataUrl ? `<img src="${s.logoDataUrl}" class="brand-logo" alt="Centre logo">` : "";
    const centreHtml = s.centreName ? `<span class="centre">${escapeHtml(s.centreName)}</span>` : "";
    return `
    <div class="topbar">
      <div class="brand">
        ${logoHtml}
        <div class="brand-names">
          <h1>Unit Ledger</h1>
          ${centreHtml || `<span class="sub">HND Practice &amp; Standing</span>`}
        </div>
      </div>
      <div style="display:flex;align-items:center;">
        ${!state.instructorUnlocked && state.mode==='student' ? `<button class="staff-link" id="staff-access-btn">Staff access</button>` : ""}
        <div class="mode-toggle">
          <button data-mode="student" class="${state.mode==='student'?'active':''}">Student</button>
          ${state.instructorUnlocked ? `<button data-mode="instructor" class="${state.mode==='instructor'?'active':''}">Instructor</button>` : ""}
        </div>
      </div>
    </div>`;
  }

  function bandStamp(band, fresh){
    const map = {
      pass:{cls:"pass", label:"Pass standard"},
      merit:{cls:"merit", label:"Merit standard"},
      distinction:{cls:"dist", label:"Distinction standard"},
      notyet:{cls:"notyet", label:"Not yet meeting Pass"},
      unattempted:{cls:"neutral", label:"Not attempted"}
    };
    const m = map[band] || map.unattempted;
    return `<span class="stamp ${m.cls}${fresh?' fresh':''}">${m.label}</span>`;
  }

  // ===================== INSTRUCTOR VIEW =====================
  function instructorHtml(){
    let html = "";
    html += centreSettingsHtml();
    html += `<div class="card">
      <h2>Units</h2>
      <p class="hint">Create a unit record, attach the assignment brief and source content, then generate practice questions per learning outcome.</p>
      <div class="unit-select-row">
        <select id="unit-select">
          <option value="">— Select a unit —</option>
          ${state.unitsIndex.map(u=>`<option value="${u.id}" ${state.currentUnitId===u.id?'selected':''}>${escapeHtml(u.name)}</option>`).join("")}
        </select>
        <button class="btn secondary" id="new-unit-btn">+ New Unit</button>
      </div>
    </div>`;

    if(state.currentUnit){
      html += unitWorkspaceHtml(state.currentUnit);
    }
    return html;
  }

  function centreSettingsHtml(){
    const s = state.settings;
    return `<div class="card">
      <h2>Centre settings</h2>
      <p class="hint">This name and logo appear in the header for both instructor and student views. The staff passcode controls who can reach this instructor area — anyone without it only ever sees the student page.</p>
      <label>Centre / school name</label>
      <input type="text" id="centre-name-input" value="${escapeHtml(s.centreName)}" placeholder="e.g. Riverside College">
      <label>Centre logo</label>
      ${s.logoDataUrl ? `<div><img src="${s.logoDataUrl}" class="logo-preview" alt="Logo preview"></div>` : ""}
      <label class="file-btn">Upload logo (image file)
        <input type="file" id="logo-file-input" accept="image/*">
      </label>
      <div class="row" style="margin-top:14px;">
        <div>
          <label>Change staff passcode</label>
          <input type="text" id="new-passcode-input" placeholder="Leave blank to keep current passcode">
        </div>
      </div>
      <button class="btn" id="save-centre-settings-btn">Save centre settings</button>
      <p class="small-note">Note: this passcode is a light deterrent to keep casual visitors on the student page — since this tool runs entirely in the browser with no server, it isn't unbreakable security. Don't use it to protect anything highly sensitive.</p>
    </div>`;
  }

  function unitWorkspaceHtml(unit){
    let html = `<div class="card">
      <label>Unit name</label>
      <input type="text" id="unit-name" value="${escapeHtml(unit.name)}" placeholder="e.g. Unit 3: Human Resource Management">
      <div class="row">
        <button class="btn secondary" id="save-unit-name-btn">Save name</button>
        <button class="btn danger" id="delete-unit-btn">Delete unit</button>
      </div>
    </div>`;

    // Assignment brief
    html += `<div class="card">
      <h2>Assignment brief</h2>
      <p class="hint">Paste the brief text, or upload the brief file, then extract the learning outcomes and Pass / Merit / Distinction criteria.</p>
      <label>Brief text</label>
      <textarea id="brief-text" placeholder="Paste the assignment brief here...">${escapeHtml(unit.assignmentBrief || "")}</textarea>
      <label class="file-btn">Upload brief (.pdf, .pptx, or .docx)
        <input type="file" id="brief-file" accept=".pdf,.pptx,.docx">
      </label>
      <div class="file-meta" id="brief-file-meta"></div>
      <div class="row">
        <button class="btn" id="extract-los-btn">Extract learning outcomes</button>
      </div>
    </div>`;

    // LOs
    html += `<div class="card">
      <h2>Learning outcomes</h2>
      <p class="hint">Review and edit what was extracted — these anchor the practice questions generated below.</p>
      <div id="lo-editor">${(unit.los||[]).map((lo,i)=>loEditHtml(lo,i)).join("") || `<p class="small-note">No learning outcomes yet. Extract them from the brief above, or add one manually.</p>`}</div>
      <button class="btn secondary" id="add-lo-btn">+ Add learning outcome manually</button>
    </div>`;

    // Source content
    html += `<div class="card">
      <h2>Source content</h2>
      <p class="hint">Only this content — lecture slides and tutorial material — will be used to write and grade questions. No outside theory is introduced.</p>
      <div class="row">
        <div>
          <label>Lecture slide content</label>
          <textarea id="slides-text" placeholder="Paste slide text here...">${escapeHtml(unit.slidesText || "")}</textarea>
